# Core app
FRONTEND_BASE_URL=https://your-frontend.vercel.app
YOUTUBE_BACKEND_REDIRECT_URI=https://your-backend.onrender.com/auth/youtube/callback

# Database
# For local SQLite dev, leave DATABASE_URL empty.
# For production (Supabase Postgres), set DATABASE_URL from Supabase -> Connect -> Transaction pooler URI.
DATABASE_URL=
AUTH_DB_PATH=app.db

# Token economy
PROCESS_TOKEN_COST=25
TRIAL_DAYS=60
TRIAL_DAILY_TOKENS=400
FREE_DAILY_TOKENS=100
PLUS_MONTHLY_TOKENS=2000
PRO_MONTHLY_TOKENS=8000

# Billing (optional)
STRIPE_SECRET_KEY=

# Email (optional, for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Limits
MAX_UPLOAD_MB=500
